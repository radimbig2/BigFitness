@page "/products"

<div class="page-content">
    <h1 class="page-title">Products</h1>

    <div class="import-export-bar">
        <button class="btn btn-secondary btn-sm" @onclick="ExportProducts" disabled="@_busy">Export JSON</button>
        <button class="btn btn-secondary btn-sm" @onclick="ImportProducts" disabled="@_busy">Import JSON</button>
    </div>

    @if (_statusMessage != null)
    {
        <div class="status-message @(_statusIsError ? "status-error" : "status-ok")">@_statusMessage</div>
    }

    <input class="search-input" placeholder="Search..." @bind="_search" @bind:event="oninput" />

    @if (_products == null)
    {
        <p class="empty-list">Loading...</p>
    }
    else if (Filtered.Count == 0)
    {
        <p class="empty-list">@(_products.Count == 0 ? "No products yet. Add one with the + button." : "Nothing found.")</p>
    }
    else
    {
        <div class="products-list">
            @foreach (var product in Filtered)
            {
                <div class="product-row">
                    <button class="btn-heart @(product.IsFavorite ? "active" : "")"
                            @onclick="() => ToggleFavorite(product)">
                        @(product.IsFavorite ? "❤️" : "🤍")
                    </button>
                    <div class="product-row-body" @onclick="() => OpenEdit(product)">
                        <div class="product-row-name">@product.Name</div>
                        <div class="product-row-meta">@product.Calories kcal / 100g &nbsp;·&nbsp; P @product.Proteins g &nbsp;·&nbsp; F @product.Fats g &nbsp;·&nbsp; C @product.Carbs g</div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<button class="fab" @onclick="OpenAdd">+</button>

@if (_showModal)
{
    <div class="modal-overlay" @onclick="CloseModal">
        <div class="modal-content" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>@(_isNew ? "Add Product" : "Edit Product")</h3>
                <button class="btn-close" @onclick="CloseModal">×</button>
            </div>
            <div class="modal-body">
                <div class="form-group">
                    <label>Name</label>
                    <input @bind="_editName" placeholder="Product name" />
                </div>
                <div class="form-group">
                    <label>Calories (per 100g)</label>
                    <input type="number" @bind="_editCalories" />
                </div>
                <div class="form-group">
                    <label>Proteins (g)</label>
                    <input type="number" @bind="_editProteins" />
                </div>
                <div class="form-group">
                    <label>Fats (g)</label>
                    <input type="number" @bind="_editFats" />
                </div>
                <div class="form-group">
                    <label>Carbs (g)</label>
                    <input type="number" @bind="_editCarbs" />
                </div>
                <div class="form-group">
                    <label>Default portion (g)</label>
                    <input type="number" @bind="_editPortion" />
                </div>

                @if (_duplicateWarning)
                {
                    <div class="warning-text">A product with this name already exists.</div>
                }

                <div class="modal-actions">
                    <button class="btn btn-primary btn-block" @onclick="SaveProduct">
                        @(_isNew ? "Add" : "Save")
                    </button>
                    @if (!_isNew)
                    {
                        <button class="btn btn-danger btn-block" @onclick="() => _showDeleteConfirm = true">
                            Delete
                        </button>
                    }
                </div>
            </div>
        </div>
    </div>
}

@if (_showDeleteConfirm)
{
    <div class="modal-overlay" @onclick="() => _showDeleteConfirm = false">
        <div class="modal-content modal-confirm" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h3>Delete Product</h3>
            </div>
            <div class="modal-body">
                <p>Delete <strong>@_editName</strong>? This cannot be undone.</p>
                <div class="modal-actions">
                    <button class="btn btn-danger btn-block" @onclick="ConfirmDelete">Delete</button>
                    <button class="btn btn-secondary btn-block" @onclick="() => _showDeleteConfirm = false">Cancel</button>
                </div>
            </div>
        </div>
    </div>
}