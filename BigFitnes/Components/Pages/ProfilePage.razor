@page "/profile"

<div class="page-content">
    <h2 class="page-title">Profile</h2>

    @if (_profile is not null)
    {
        <div class="form-section">
            <h3>Appearance</h3>
            <div class="theme-toggle-row">
                <span>Dark theme</span>
                <label class="toggle-switch">
                    <input type="checkbox" checked="@_profile.IsDarkTheme" @onchange="ToggleTheme" />
                    <span class="toggle-slider"></span>
                </label>
            </div>
        </div>

        <div class="form-section">
            <h3>Personal Info</h3>
            <div class="form-group">
                <label>Name</label>
                <input type="text" @bind="_editName" />
            </div>
            <div class="form-group">
                <label>Height (cm)</label>
                <input type="number" @bind="_editHeight" step="1" />
            </div>
            <div class="form-group">
                <label>Goal Weight (kg)</label>
                <input type="number" @bind="_editGoalWeight" step="0.1" />
            </div>
            <div class="form-group">
                <label>Age</label>
                <input type="number" @bind="_editAge" step="1" />
            </div>
            <div class="form-group">
                <label>Gender</label>
                <select @bind="_editGender">
                    <option value="@Gender.Male">Male</option>
                    <option value="@Gender.Female">Female</option>
                </select>
            </div>
            <div class="form-group">
                <label>Activity Level</label>
                <select @bind="_editActivityLevel">
                    <option value="@ActivityLevel.Sedentary">Sedentary (office work)</option>
                    <option value="@ActivityLevel.Light">Light (1-2 workouts/week)</option>
                    <option value="@ActivityLevel.Moderate">Moderate (3-5 workouts/week)</option>
                    <option value="@ActivityLevel.High">High (6-7 workouts/week)</option>
                    <option value="@ActivityLevel.VeryHigh">Very High (2x/day, physical job)</option>
                </select>
            </div>
        </div>

        @if (_editAge > 0 && _latestWeight > 0)
        {
            <div class="form-section">
                <h3>TDEE Dashboard</h3>
                <div class="tdee-dashboard">
                    <div class="tdee-card @(_editCalorieGoalMode == CalorieGoalMode.WeightLoss ? "active" : "")"
                         @onclick="() => SelectMode(CalorieGoalMode.WeightLoss)">
                        <div class="tdee-card-value">@((int)GetWeightLossCalories()) kcal</div>
                        <div class="tdee-card-label">For weight loss</div>
                    </div>
                    <div class="tdee-card @(_editCalorieGoalMode == CalorieGoalMode.Maintenance ? "active" : "")"
                         @onclick="() => SelectMode(CalorieGoalMode.Maintenance)">
                        <div class="tdee-card-value">@((int)CalcTDEE()) kcal</div>
                        <div class="tdee-card-label">For keeping weight</div>
                    </div>
                </div>
            </div>
        }

        <div class="form-section">
            <h3>Daily Goals</h3>
            <div class="form-group">
                <label>Calories (kcal)</label>
                <div class="calorie-input-row">
                    <input type="number"
                           class="@(_editCalorieGoalMode != CalorieGoalMode.Manual ? "calorie-input-disabled" : "")"
                           disabled="@(_editCalorieGoalMode != CalorieGoalMode.Manual)"
                           @bind="_editDailyCalorieGoal" step="50" />
                </div>
            </div>
            @if (_editAge > 0 && _latestWeight > 0)
            {
                <div class="theme-toggle-row" style="margin-bottom: 12px;">
                    <span style="font-size: 14px;">Manual input</span>
                    <label class="toggle-switch">
                        <input type="checkbox"
                               checked="@(_editCalorieGoalMode == CalorieGoalMode.Manual)"
                               @onchange="ToggleManualMode" />
                        <span class="toggle-slider"></span>
                    </label>
                </div>
            }
            <div class="form-group">
                <label>Protein (g)</label>
                <input type="number" @bind="_editDailyProteinGoal" step="5" />
            </div>
            <div class="form-group">
                <label>Fats (g)</label>
                <input type="number" @bind="_editDailyFatGoal" step="5" />
            </div>
            <div class="form-group">
                <label>Carbs (g)</label>
                <input type="number" @bind="_editDailyCarbGoal" step="5" />
            </div>
        </div>

        <button class="btn btn-primary btn-block" @onclick="Save">
            @(_saved ? "Saved!" : "Save Profile")
        </button>
    }
</div>

<style>
    .tdee-dashboard {
        display: flex;
        gap: 12px;
    }

    .tdee-card {
        flex: 1;
        background: var(--bg);
        border: 2px solid var(--border);
        border-radius: 12px;
        padding: 16px;
        text-align: center;
        cursor: pointer;
        transition: border-color 0.2s;
    }

    .tdee-card:active {
        opacity: 0.85;
    }

    .tdee-card.active {
        border-color: var(--primary);
    }

    .tdee-card-value {
        font-size: 22px;
        font-weight: 700;
        color: var(--text);
        margin-bottom: 4px;
    }

    .tdee-card-label {
        font-size: 12px;
        color: var(--text-secondary);
    }

    .calorie-input-disabled {
        opacity: 0.5;
        background: var(--bg) !important;
    }

    .form-group select {
        width: 100%;
        padding: 10px 14px;
        border: 1px solid var(--border);
        border-radius: 10px;
        font-size: 15px;
        outline: none;
        background: var(--card-bg);
        color: var(--text);
        -webkit-appearance: none;
        appearance: none;
    }

    .form-group select:focus {
        border-color: var(--primary);
    }
</style>