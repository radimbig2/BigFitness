@page "/weight"

<div class="page-content">
    <h2 class="page-title">Weight Tracker</h2>

    <div class="weight-input-card">
        <div class="weight-input-group">
            <input type="number" class="weight-input" @bind="_weightInput" step="0.1" min="30" max="300" placeholder="Weight (kg)" />
            <button class="btn btn-primary" @onclick="SaveWeight">Save</button>
        </div>
    </div>

    <div class="stat-cards">
        <div class="stat-card">
            <div class="stat-label">Current</div>
            <div class="stat-value">@(_latestWeight?.Weight.ToString("0.0") ?? "—") kg</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Goal</div>
            <div class="stat-value">@(_profile.GoalWeight?.ToString("0.0") ?? "—") kg</div>
        </div>
        <div class="stat-card">
            <div class="stat-label">Optimal (BMI)</div>
            <div class="stat-value">@_optimalWeight.ToString("0.0") kg</div>
        </div>
        <div class="stat-card @(_toGoalClass)">
            <div class="stat-label">To Goal</div>
            <div class="stat-value">@_toGoalText</div>
        </div>
    </div>

    <div class="chart-section">
        <h3>Last 30 Days</h3>
        <WeightChart Records="@_history" GoalWeight="@_profile.GoalWeight" />
    </div>

    @if (_caloriePoints.Any())
    {
        <div class="chart-section">
            <h3>Calories per Hour (7 days)</h3>
            <CalorieChart DailyCalories="@_caloriePoints"
                          MaintenanceCalories="@_maintenanceCalories"
                          WeightLossCalories="@_weightLossCalories" />
        </div>
    }
</div>