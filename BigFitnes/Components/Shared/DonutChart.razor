@* SVG Donut Chart showing consumed vs goal calories *@

<div class="donut-chart-container">
    <svg viewBox="0 0 200 200" class="donut-chart">
        @* Background circle *@
        <circle cx="100" cy="100" r="80" fill="none" class="donut-bg-track" stroke-width="20" />
        @* Progress arc *@
        @if (Percentage > 0)
        {
            <circle cx="100" cy="100" r="80"
                    fill="none"
                    stroke="@ProgressColor"
                    stroke-width="20"
                    stroke-dasharray="@DashArray"
                    stroke-dashoffset="@DashOffset"
                    stroke-linecap="round"
                    transform="rotate(-90 100 100)" />
        }
        @* Center text *@
        @((MarkupString)$"<text x=\"100\" y=\"80\" text-anchor=\"middle\" class=\"donut-emoji\">{Emoji}</text>")
        @((MarkupString)$"<text x=\"100\" y=\"107\" text-anchor=\"middle\" class=\"donut-consumed\">{Consumed:0}</text>")
        @((MarkupString)$"<text x=\"100\" y=\"125\" text-anchor=\"middle\" class=\"donut-goal\">/ {Goal:0} kcal</text>")
    </svg>
</div>