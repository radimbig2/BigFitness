
@if (IsVisible)
{
    <div class="modal-overlay" @onclick="Close">
        <div class="modal-content" @onclick:stopPropagation>
            <div class="modal-header">
                <h3>Add Food</h3>
                <button class="btn-close" @onclick="Close">&times;</button>
            </div>

            @if (_selectedProduct is null)
            {
                <div class="modal-body">
                    <input type="text" class="search-input" placeholder="Search products..."
                           @bind="_searchQuery" @bind:event="oninput" @bind:after="SearchAsync" />

                    <div class="tab-switcher">
                        <button class="tab-btn @(_showFrequent ? "active" : "")" @onclick="() => SwitchTab(true)">Frequent</button>
                        <button class="tab-btn @(!_showFrequent ? "active" : "")" @onclick="() => SwitchTab(false)">All</button>
                    </div>

                    <div class="product-list">
                        @foreach (var product in _displayProducts)
                        {
                            <div class="product-item" @onclick="() => SelectProduct(product)">
                                <div class="product-name">@product.Name</div>
                                <div class="product-info">@product.Calories kcal/100g | @(product.DefaultPortionGrams)g portion</div>
                            </div>
                        }
                        @if (!_displayProducts.Any())
                        {
                            <div class="empty-list">No products found</div>
                        }
                    </div>
                </div>
            }
            else
            {
                <div class="modal-body">
                    <div class="selected-product-name">@_selectedProduct.Name</div>
                    <div class="portion-input-group">
                        <label>Portion (grams):</label>
                        <input type="number" class="portion-input" @bind="_portionGrams" @bind:after="OnPortionChanged" min="1" step="10" />
                    </div>
                    <div class="portion-preview">
                        <span>@((_selectedProduct.Calories * _portionGrams / 100).ToString("0")) kcal</span>
                        <span>P: @((_selectedProduct.Proteins * _portionGrams / 100).ToString("0.0"))g</span>
                        <span>F: @((_selectedProduct.Fats * _portionGrams / 100).ToString("0.0"))g</span>
                        <span>C: @((_selectedProduct.Carbs * _portionGrams / 100).ToString("0.0"))g</span>
                    </div>
                    <div class="serving-actions">
                        <button class="btn btn-serving btn-minus" @onclick="RemoveServing">−1</button>
                        <span class="serving-count">@_servingCount.ToString("0.##") pcs</span>
                        <button class="btn btn-serving btn-plus" @onclick="AddServing">+1</button>
                    </div>
                    <div class="modal-actions">
                        <button class="btn btn-secondary" @onclick="() => _selectedProduct = null">Back</button>
                        <button class="btn btn-primary" @onclick="ConfirmAdd">Add</button>
                    </div>
                </div>
            }
        </div>
    </div>
}