
@inherits LayoutComponentBase

<div class="app-container @(_themeCss)">
    <main class="app-main">
        @Body
    </main>

    <nav class="tab-bar">
        <a class="tab-item @IsActive("/")" href="/">
            <svg class="tab-icon" viewBox="0 0 24 24" fill="currentColor"><path d="M11 21H5c-1.1 0-2-.9-2-2V5c0-1.1.9-2 2-2h6v18zm2 0h6c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2h-6v18z"/></svg>
            <span class="tab-label">Calories</span>
        </a>
        <a class="tab-item @IsActive("/weight")" href="/weight">
            <svg class="tab-icon" viewBox="0 0 24 24" fill="currentColor"><path d="M12 3C7.03 3 3 7.03 3 12s4.03 9 9 9 9-4.03 9-9-4.03-9-9-9zm0 16c-3.87 0-7-3.13-7-7s3.13-7 7-7 7 3.13 7 7-3.13 7-7 7zm1-11h-2v4H7v2h4v4h2v-4h4v-2h-4V8z"/></svg>
            <span class="tab-label">Weight</span>
        </a>
        <a class="tab-item @IsActive("/products")" href="/products">
            <svg class="tab-icon" viewBox="0 0 24 24" fill="currentColor">
                <path d="M3 13h2v-2H3v2zm0 4h2v-2H3v2zm0-8h2V7H3v2zm4 4h14v-2H7v2zm0 4h14v-2H7v2zM7 7v2h14V7H7z"/>
            </svg>
            <span class="tab-label">Products</span>
        </a>
        <a class="tab-item @IsActive("/profile")" href="/profile">
            <svg class="tab-icon" viewBox="0 0 24 24" fill="currentColor"><path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/></svg>
            <span class="tab-label">Profile</span>
        </a>
    </nav>
</div>